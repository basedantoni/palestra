# Server environment variables.
# Copy to `.env` and fill in real values: `cp apps/server/.env.example apps/server/.env`
# Validated at startup by packages/env/src/server.ts (zod) — a missing/invalid
# required var crashes the server on boot. Never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────

# Postgres connection string. Default matches packages/db/docker-compose.yml
# (host port 5433 → container 5432, db "life-tracker").
DATABASE_URL="postgres://postgres:password@localhost:5433/life-tracker"

# Better-Auth signing secret. Min 32 chars. Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-32+-char-random-string"

# Public base URL of this server. Used by Better-Auth for callbacks/cookies.
BETTER_AUTH_URL="http://localhost:3000"

# Allowed browser origin for CORS (the web app). Must be a full URL.
CORS_ORIGIN="http://localhost:3001"

# ── Optional ──────────────────────────────────────────────────────────────

# Comma-separated admin emails. Grants access to adminProcedure routes. Omit = no admins.
ADMIN_EMAILS="you@example.com"

# Runtime mode: development | production | test. Defaults to "development".
NODE_ENV="development"

# Whoop OAuth app credentials. All three required together to enable Whoop sync; omit to disable.
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
WHOOP_REDIRECT_URI="http://localhost:3000/api/whoop/callback"

# AES key for encrypting stored Whoop OAuth tokens. Exactly 64 hex chars (32 bytes).
# Generate: `openssl rand -hex 32`. Required if Whoop sync is enabled.
TOKEN_ENCRYPTION_KEY=""

# Shared secret for internal server-to-server endpoints. Min 32 chars.
INTERNAL_API_SECRET=""

# Cookie domain override for cross-subdomain auth in production (e.g. ".example.com").
COOKIE_DOMAIN=""
