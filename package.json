{
  "name": "life-tracker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "clean": "pnpm recursive exec -- rm -rf node_modules .turbo dist tsconfig.tsbuildinfo",
    "import:nike-tcx": "cd apps/server && tsx ../../scripts/import-nike-tcx.ts",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @life-tracker/db db:push",
    "db:studio": "turbo -F @life-tracker/db db:studio",
    "db:generate": "turbo -F @life-tracker/db db:generate",
    "db:migrate": "turbo -F @life-tracker/db db:migrate",
    "db:seed": "turbo -F @life-tracker/db db:seed",
    "db:start": "turbo -F @life-tracker/db db:start",
    "db:watch": "turbo -F @life-tracker/db db:watch",
    "db:stop": "turbo -F @life-tracker/db db:stop",
    "db:down": "turbo -F @life-tracker/db db:down"
  },
  "dependencies": {
    "@life-tracker/db": "workspace:*",
    "@life-tracker/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@life-tracker/config": "workspace:*",
    "@types/node": "^22.13.14",
    "oxlint": "^1.70.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.22.0",
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk>@hono/node-server": "1.19.14"
    }
  }
}
